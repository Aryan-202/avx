# This is crucial for cross-platform Zig projects.
* text=auto eol=lf

# Zig source code and package manager files
*.zig text eol=lf linguist-language=Zig
*.zon text eol=lf linguist-language=Zig

# Common documentation and config files
*.md text
*.txt text
*.json text
.gitignore text
.gitattributes text

# Shell scripts
*.sh text eol=lf

# Windows batch/PowerShell scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Compiled binaries and libraries
*.exe binary
*.dll binary
*.lib binary
*.so binary
*.a binary
*.dylib binary
*.pdb binary
*.o binary
*.obj binary